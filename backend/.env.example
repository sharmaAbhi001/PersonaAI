# Server
# Production on Render: NODE_ENV=production
NODE_ENV=development
PORT=8000

# Local:  http://localhost:8000
# Render: https://your-backend.onrender.com
BACKEND_URL=http://localhost:8000

# CORS origin — must match the live frontend origin exactly (no trailing slash)
# Local:  http://localhost:5173
# Vercel: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Database (Neon / PostgreSQL)
# Example: postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=

# Auth / JWT
JWT_SECRET=
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d


# Google OAuth (must match frontend VITE_GOOGLE_* and Google Cloud Console)
# GOOGLE_REDIRECT_URI must equal VITE_GOOGLE_REDIRECT_URI exactly
# Local:  http://localhost:5173/login
# Vercel: https://your-app.vercel.app/login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/login
GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_ISSUER=https://accounts.google.com

# Sarvam LLM
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_MODEL=sarvam-105b

# YouTube Data API — persona video recommendations
YOUTUBE_API_KEY=
YOUTUBE_API_BASE_URL=https://www.googleapis.com/youtube/v3
YOUTUBE_WATCH_BASE_URL=https://www.youtube.com/watch
CHAI_AUR_CODE_CHANNEL_ID=UCNQ6FEtztATuaVhZKCY28Yw
PIYUSH_GARG_CHANNEL_ID=UCf9T51_FmMlfhiGpoes0yFA
