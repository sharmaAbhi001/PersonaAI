# App URLs
# Local:  http://localhost:5173
# Vercel: https://your-app.vercel.app
VITE_APP_URL=http://localhost:5173

# Backend API base (must include /api)
# Local:  http://localhost:8000/api
# Render: https://your-backend.onrender.com/api
VITE_API_URL=http://localhost:8000/api

# Google OAuth (must match backend GOOGLE_* and Google Cloud Console)
# Authorized redirect URI in Google Console must be exactly VITE_GOOGLE_REDIRECT_URI
# Local:  http://localhost:5173/login
# Vercel: https://your-app.vercel.app/login
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/login
VITE_GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
